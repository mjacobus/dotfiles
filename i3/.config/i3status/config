# Minimal status for a desktop: no battery, no ipv6, no load average.
# Everything labeled so it's obvious what each number is.

general {
        colors = true
        interval = 5
}

order += "wireless _first_"
order += "ethernet _first_"
order += "disk /"
order += "memory"
order += "tztime local"

wireless _first_ {
        format_up = "wifi: %ip (%quality)"
        format_down = ""
}

ethernet _first_ {
        format_up = "eth: %ip"
        format_down = "eth: down"
}

disk "/" {
        format = "disk: %avail"
}

memory {
        format = "ram: %available"
        threshold_degraded = "1G"
        format_degraded = "RAM BAIXA: %available"
}

tztime local {
        format = "%Y-%m-%d %H:%M"
}
